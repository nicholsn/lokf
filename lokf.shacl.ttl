            sh:path schema1:sameAs ],
        [ sh:datatype xsd:string ;
            sh:description "The concept's type. OKF's single required field. In LOKF the value SHOULD name a LOKF class (e.g. Metric, Dataset, Table, Playbook, GlossaryTerm); it designates the JSON-LD @type / rdf:type. Consumers MUST tolerate unknown values by treating the concept as a generic lokf:Concept." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lokf:type ] ;
    sh:targetClass lokf:Table .

schema1:PropertyValue a sh:NodeShape ;
    rdfs:comment "A single column / property within a Table or Dataset schema. Maps to schema:PropertyValue." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text or expression describing constraints on a field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lokf:constraints ],
        [ sh:description "The data type of a field." ;
            sh:in ( xsd:string xsd:integer xsd:decimal xsd:boolean xsd:date xsd:dateTime xsd:time xsd:anyURI rdf:JSON ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path lokf:datatype ],
        [ sh:datatype xsd:string ;
            sh:description "A single-sentence summary of the concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:description ],
        [ sh:datatype xsd:string ;
            sh:description "The unit of measurement (e.g. USD, seconds, count)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:unitText ],
        [ sh:datatype xsd:string ;
            sh:description "A name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the field is (part of) the primary key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lokf:isKey ] ;
    sh:targetClass schema1:PropertyValue .

dcat:Distribution a sh:NodeShape ;
    rdfs:comment "A specific accessible form of a Dataset (a file, feed, or endpoint). Maps to dcat:Distribution." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A URL that gives access to a distribution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path dcat:accessURL ],
        [ sh:datatype xsd:string ;
            sh:description "A name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "The media (MIME) type of a distribution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcat:mediaType ],
        [ sh:datatype xsd:string ;
            sh:description "A single-sentence summary of the concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:description ] ;
    sh:targetClass dcat:Distribution .

schema1:CreativeWork a sh:NodeShape ;
    rdfs:comment "A reference to an external source supporting a claim in a concept's body. Attached via the schema:citation predicate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A single-sentence summary of the concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:description ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable display name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:name ],
        [ sh:description "A URL." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema1:url ] ;
    sh:targetClass schema1:CreativeWork .

rdf:Statement a sh:NodeShape ;
    rdfs:comment "A typed, reified relationship from the containing concept to a target, used when a predicate is not covered by one of the named relation slots. Modeled as an rdf:Statement (subject = the containing concept)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An optional human-readable label for the relationship." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ],
        [ sh:class lokf:Concept ;
            sh:description "The IRI (or Concept ID) of the relationship's object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path rdf:object ],
        [ sh:description "The relationship type. SHOULD be drawn from the RelationType vocabulary." ;
            sh:in ( dcterms:isPartOf schema1:hasPart dcterms:references dcterms:requires prov:wasDerivedFrom schema1:about owl:sameAs dcterms:relation prov:wasAttributedTo rdfs:isDefinedBy lokf:measures lokf:joinsWith dcterms:source schema1:memberOf org:member ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path rdf:predicate ] ;
    sh:targetClass rdf:Statement .

prov:Agent a sh:NodeShape ;
    rdfs:comment "A person or organization responsible for a concept." ;
    sh:closed false ;
    sh:ignoredProperties ( lokf:relations dcterms:source schema1:dateCreated schema1:description rdfs:isDefinedBy schema1:author schema1:dateModified schema1:url dcterms:requires schema1:about schema1:sameAs schema1:text schema1:citation prov:wasDerivedFrom dcterms:references schema1:license dcterms:isPartOf schema1:version schema1:keywords dcterms:relation schema1:hasPart rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Contact email address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:email ],
        [ sh:datatype xsd:string ;
            sh:description "The concept's type. OKF's single required field. In LOKF the value SHOULD name a LOKF class (e.g. Metric, Dataset, Table, Playbook, GlossaryTerm); it designates the JSON-LD @type / rdf:type. Consumers MUST tolerate unknown values by treating the concept as a generic lokf:Concept." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lokf:type ],
        [ sh:description "The concept's stable IRI. By convention it is the bundle base IRI joined with the Concept ID (the file path within the bundle, minus the `.md` suffix). Becomes the JSON-LD @id / RDF subject." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema1:identifier ] ;
    sh:targetClass prov:Agent .

lokf:Concept a sh:NodeShape ;
    rdfs:comment "A single unit of knowledge within a bundle, represented as one markdown document. The abstract base of every LOKF type. Its own IRI (`id`) is the RDF subject; the markdown body and typed relations become triples about that subject." ;
    sh:closed false ;
    sh:ignoredProperties ( schema1:endDate lokf:field schema1:httpMethod schema1:memberOf skos:definition schema1:unitText lokf:formula schema1:roleName lokf:measures schema1:startDate org:member schema1:alternateName dcat:distribution rdf:type schema1:documentation ) ;
    sh:property [ sh:class lokf:Concept ;
            sh:description "A resource that formally defines this concept." ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:description "A version string for the concept's content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path schema1:version ],
        [ sh:datatype xsd:dateTime ;
            sh:description "ISO 8601 datetime of the last meaningful change." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path schema1:dateModified ],
        [ sh:class lokf:Concept ;
            sh:description "An entity this concept was derived from (provenance)." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path prov:wasDerivedFrom ],
        [ sh:class lokf:Concept ;
            sh:description "The subject matter this concept is about." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path schema1:about ],
        [ sh:class lokf:Concept ;
            sh:description "A generic association to another concept." ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path dcterms:relation ],
        [ sh:description "The license under which the concept or bundle is offered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path schema1:license ],
        [ sh:datatype xsd:string ;
            sh:description "A single-sentence summary of the concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:description ],
        [ sh:class lokf:Concept ;
            sh:description "A resource from which this concept is derived or sourced." ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path dcterms:source ],
        [ sh:class lokf:Concept ;
            sh:description "A concept this concept depends on." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path dcterms:requires ],
        [ sh:datatype xsd:string ;
            sh:description "The concept's type. OKF's single required field. In LOKF the value SHOULD name a LOKF class (e.g. Metric, Dataset, Table, Playbook, GlossaryTerm); it designates the JSON-LD @type / rdf:type. Consumers MUST tolerate unknown values by treating the concept as a generic lokf:Concept." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lokf:type ],
        [ sh:class rdf:Statement ;
            sh:description "Typed relationships whose predicate is not covered by a named relation slot. Each entry is a reified Relation (predicate + target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lokf:relations ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable display name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:name ],
        [ sh:class lokf:Concept ;
            sh:description "A concept that is a part of this concept." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path schema1:hasPart ],
        [ sh:class lokf:Concept ;
            sh:description "An IRI asserting this concept is the same entity as another." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path schema1:sameAs ],
        [ sh:description "The concept's stable IRI. By convention it is the bundle base IRI joined with the Concept ID (the file path within the bundle, minus the `.md` suffix). Becomes the JSON-LD @id / RDF subject." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:class prov:Agent ;
            sh:description "The agent(s) responsible for authoring the concept." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path schema1:author ],
        [ sh:datatype xsd:dateTime ;
            sh:description "ISO 8601 datetime the concept was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path schema1:dateCreated ],
        [ sh:datatype xsd:string ;
            sh:description "The markdown body of the concept document (everything after the frontmatter). Mapped to schema:text; carried as a field only in the JSON-LD / JSON serialization, not duplicated in the frontmatter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path schema1:text ],
        [ sh:datatype xsd:string ;
            sh:description "Short cross-cutting keywords for categorization." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path schema1:keywords ],
        [ sh:class lokf:Concept ;
            sh:description "A concept or resource this concept refers to." ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path dcterms:references ],
        [ sh:class lokf:Concept ;
            sh:description "The target concept that this concept is a part of." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path dcterms:isPartOf ],
        [ sh:class schema1:CreativeWork ;
            sh:description "External sources supporting claims in the body." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path schema1:citation ],
        [ sh:description "A URI that uniquely identifies the underlying real-world asset the concept describes (a table console URL, an API base URL, etc.). Absent for purely abstract concepts." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path schema1:url ] ;
    sh:targetClass lokf:Concept .


